# ============================================================
# Gravital Server — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit your real .env file to version control.
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Port for the Express server to listen on
PORT=8000

# Node environment: development | production | test
NODE_ENV=development

# Frontend origin URL allowed by CORS and Socket.IO
# Example: http://localhost:3000 (dev) or https://yourdomain.com (prod)
ORIGIN_URL=http://localhost:3000


# ------------------------------------------------------------
# MongoDB
# ------------------------------------------------------------

# Full MongoDB connection URI
# Local example:   mongodb://localhost:27017/gravital
# Atlas example:   mongodb+srv://<user>:<password>@cluster.mongodb.net/gravital
MONGO_URI=mongodb://localhost:27017/gravital


# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------

# Redis server host
# Local: 127.0.0.1
# Cloud (e.g., Redis Cloud, Upstash): your-redis-host.example.com
REDIS_HOST=127.0.0.1

# Redis server port (default: 6379)
REDIS_PORT=6379

# Redis password (leave blank if no authentication is configured locally)
REDIS_PASSWORD=


# ------------------------------------------------------------
# JSON Web Tokens (JWT)
# ------------------------------------------------------------

# Secret key used to sign and verify short-lived access tokens
# Use a long, random, cryptographically secure string (min 32 chars recommended)
ACCESS_TOKEN_SECRET=your_super_secret_access_token_key_here

# Lifetime of a generated access token
# Examples: 15m, 1h, 2h
ACCESS_TOKEN_LIFETIME=15m

# Secret key used to sign and verify long-lived refresh tokens
# Must be different from ACCESS_TOKEN_SECRET
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_here

# Lifetime of a generated refresh token
# Examples: 7d, 30d
REFRESH_TOKEN_LIFETIME=7d


# ------------------------------------------------------------
# Nodemailer (Gmail SMTP — OTP Email Delivery)
# ------------------------------------------------------------

# Gmail address used as the sender for OTP emails
NODEMAILER_EMAIL=your_email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your Google account)
NODEMAILER_PASSWORD=your_gmail_app_password_here


# ------------------------------------------------------------
# AWS S3 (Media File Storage)
# ------------------------------------------------------------

# AWS IAM Access Key ID with S3 permissions
AWS_S3_ACCESS_KEY_ID=your_aws_access_key_id_here

# AWS IAM Secret Access Key
AWS_S3_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# S3 bucket name for storing USER PROFILE IMAGES
AWS_S3_BUCKET_NAME=gravital-profile-images

# S3 bucket name for storing POST MEDIA (images and videos)
AWS_S3_POST_BUCKET_NAME=gravital-post-media

# AWS region where your S3 buckets are located
# Examples: ap-south-1, us-east-1, eu-west-1
AWS_S3_BUCKET_REGION=ap-south-1


# ------------------------------------------------------------
# Mediasoup WebRTC Live Streaming
# ------------------------------------------------------------

# The public IP address announced to WebRTC clients for ICE negotiation.
# - For local development: 127.0.0.1
# - For production: your server's public IPv4 address (e.g., 65.2.100.200)
# Note: The server listens on 0.0.0.0 but announces this IP to peers.
ANNOUNCED_IP=127.0.0.1
